{
  "version": "1.0.0",
  "brand": "Making Sense",

  "color": {
    "msGreen":          "#0ECC7E",
    "msBlue":           "#00C6D1",
    "msDark":           "#102532",
    "msGreenDeep":      "#08B368",
    "msBlueDeep":       "#00A8B2",
    "msMint":           "#7FE3C2",
    "msMintPale":       "#E6FAF3",

    "msSecondaryPurple": "#9273F4",
    "msSecondaryRed":    "#FF5551",
    "msSecondaryOrange": "#FFA143",

    "msWhite":    "#FFFFFF",
    "msGrey50":   "#F9F9F9",
    "msGrey100":  "#F4F4F4",
    "msGrey200":  "#EEEEEE",
    "msGrey300":  "#E0E0E0",
    "msGrey400":  "#BDBDBD",
    "msGrey500":  "#9E9E9E",
    "msGrey600":  "#757575",
    "msGrey700":  "#616161",
    "msGrey800":  "#424242",
    "msGrey900":  "#212121",
    "msBlack":    "#000000",

    "msSuccess":  "#0ECC7E",
    "msWarning":  "#FFA143",
    "msDanger":   "#FF5551",
    "msInfo":     "#00C6D1"
  },

  "gradient": {
    "horizontal": "linear-gradient(90deg, #0ECC7E 0%, #00C6D1 100%)",
    "vertical":   "linear-gradient(180deg, #0ECC7E 0%, #00C6D1 100%)",
    "diagonal":   "linear-gradient(135deg, #0ECC7E 0%, #00C6D1 100%)",
    "stops": ["#0ECC7E", "#00C6D1"]
  },

  "typography": {
    "fontFamily": "Red Hat Display",
    "fontFamilyFallback": "ui-sans-serif, system-ui, -apple-system, sans-serif",
    "weights": {
      "light":     300,
      "regular":   400,
      "medium":    500,
      "semibold":  600,
      "bold":      700,
      "extrabold": 800,
      "black":     900
    },
    "scale": {
      "12": { "size": "0.75rem",  "lineHeight": 1.5  },
      "14": { "size": "0.875rem", "lineHeight": 1.5  },
      "16": { "size": "1rem",     "lineHeight": 1.6  },
      "18": { "size": "1.125rem", "lineHeight": 1.55 },
      "20": { "size": "1.25rem",  "lineHeight": 1.5  },
      "24": { "size": "1.5rem",   "lineHeight": 1.4  },
      "32": { "size": "2rem",     "lineHeight": 1.25 },
      "40": { "size": "2.5rem",   "lineHeight": 1.15 },
      "56": { "size": "3.5rem",   "lineHeight": 1.05 },
      "72": { "size": "4.5rem",   "lineHeight": 1.0  }
    },
    "letterSpacing": {
      "tight":   "-0.02em",
      "snug":    "-0.01em",
      "normal":  "0",
      "wide":    "0.04em",
      "eyebrow": "0.12em"
    }
  },

  "spacing": {
    "1":  "4px",
    "2":  "8px",
    "3":  "12px",
    "4":  "16px",
    "5":  "20px",
    "6":  "24px",
    "8":  "32px",
    "10": "40px",
    "12": "48px",
    "16": "64px",
    "20": "80px",
    "24": "96px",
    "32": "128px"
  },

  "radii": {
    "xs":   "4px",
    "sm":   "6px",
    "md":   "10px",
    "lg":   "16px",
    "xl":   "24px",
    "pill": "999px"
  },

  "shadows": {
    "xs": "0 1px 2px rgba(0,0,0,0.06)",
    "sm": "0 2px 6px rgba(0,0,0,0.08)",
    "md": "0 8px 20px rgba(0,0,0,0.10)",
    "lg": "0 20px 40px rgba(0,0,0,0.14)"
  },

  "motion": {
    "easeOut":   "cubic-bezier(0.2, 0.8, 0.2, 1)",
    "easeInOut": "cubic-bezier(0.5, 0, 0.2, 1)",
    "fast":  "120ms",
    "base":  "200ms",
    "slow":  "320ms"
  },

  "rules": {
    "buttonRadius":        "Always 999px (pill). No exceptions.",
    "gradientButtonText":  "Always --ms-dark (#102532), weight 800 (ExtraBold).",
    "buttonContent":       "Text only. No icons, arrows or symbols.",
    "eyebrowColor":        "Always --ms-green (#0ECC7E), uppercase, letter-spacing 0.12em.",
    "shadows":             "Neutral grey only. Never tinted or colored shadows.",
    "svgScaling":          "Scale proportionally only. Never distort. Use width + height:auto or object-fit:contain.",
    "headingCase":         "Sentence case always. No Title Case.",
    "emoji":               "Never. Use brand SVG icons instead.",
    "gradientUsage":       "Accent only — never full-bleed background wallpaper."
  }
}
